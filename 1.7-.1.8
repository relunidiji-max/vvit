-- ЗАПРОСЫ С УСЛОВИЯМИ:

-- 1. Запрос к group (группы, где в описании есть "Информатика")
SELECT * FROM `group` WHERE description LIKE '%Информатика%';

-- 2. Запрос к student (студенты 1-й группы)
SELECT * FROM student WHERE group_id = 1;

-- 3. Запрос к student_marks (математика выше 4.5)
SELECT student_id, math_mark_average FROM student_marks WHERE math_mark_average > 4.5;

-- 4. JOIN-запрос (студенты + названия групп)
SELECT student.name, `group`.name AS group_name
FROM student
JOIN `group` ON student.group_id = `group`.id;
