# Обновление таблиц с усиленным контролем

DROP TABLE IF EXISTS student_marks;
DROP TABLE IF EXISTS student;
DROP TABLE IF EXISTS `group`;

CREATE TABLE `group` (
    id INTEGER PRIMARY KEY,
    name VARCHAR(255) UNIQUE NOT NULL,
    description VARCHAR(255) NOT NULL
);

CREATE TABLE student (
    id INTEGER PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    group_id INTEGER NOT NULL,
    FOREIGN KEY (group_id) REFERENCES `group`(id) ON DELETE RESTRICT
);

CREATE TABLE student_marks (
    student_id INTEGER PRIMARY KEY,
    math_mark_average FLOAT CHECK (math_mark_average BETWEEN 2 AND 5),
    physics_mark_average FLOAT CHECK (physics_mark_average BETWEEN 2 AND 5),
    python_mark_average FLOAT CHECK (python_mark_average BETWEEN 2 AND 5),
    FOREIGN KEY (student_id) REFERENCES student(id) ON DELETE CASCADE
);

