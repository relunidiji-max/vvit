# Ошибка NULL в NOT NULL
CREATE TABLE `group` (id INTEGER PRIMARY KEY, name VARCHAR(255), description VARCHAR(255) NOT NULL);
INSERT INTO `group` VALUES (1, 'Тест', NULL);

#Ошибка дублирования PK
CREATE TABLE `group` (id INTEGER PRIMARY KEY, name VARCHAR(255), description VARCHAR(255));
INSERT INTO `group` VALUES (1, 'А', 'описание');
INSERT INTO `group` VALUES (1, 'Б', 'другое');

#Ошибка внешнего ключа
CREATE TABLE `group` (id INTEGER PRIMARY KEY, name VARCHAR(255), description VARCHAR(255));
CREATE TABLE student (id INTEGER PRIMARY KEY, name VARCHAR(255), group_id INTEGER REFERENCES `group`(id));
INSERT INTO student VALUES (1, 'Тест', 999);
